# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# See: https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# JavaScript, TypeScript, JSX, TSX
[*.{js,jsx,ts,tsx,mjs}]
indent_size = 2
max_line_length = 100

# JSON, JSONC
[*.{json,jsonc}]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# Python
[*.py]
indent_size = 4
max_line_length = 100

# Markdown
[*.md]
trim_trailing_whitespace = false

# Shell scripts
[*.{sh,bash}]
indent_size = 2

# Makefile
[Makefile]
indent_style = tab
